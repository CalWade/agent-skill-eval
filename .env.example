# ============================================================
# Agent Skill Eval — 环境变量配置
# ============================================================
# 复制此文件为 .env 并填入你的值:
#   cp .env.example .env

# ── 必填：Agent API 配置 ──

# Agent 平台的 Chat Completions API 地址
# 必须兼容 OpenAI Chat Completions 格式
#
# 示例:
#   OpenAI:    https://api.openai.com/v1/chat/completions
#   EasyClaw:  https://api.easyclaw.work/api/v1/chats/completions
#   Dify:      https://api.dify.ai/v1/chat-messages
#   FastGPT:   https://your-fastgpt/api/v1/chat/completions
AGENT_API_URL=

# Agent 平台的 API Key 或 Bearer Token
AGENT_API_KEY=

# ── 可选：Agent 平台参数 ──

# 模型名称（如果平台需要）
# AGENT_MODEL=gpt-4o

# 平台特定的额外参数（JSON 格式，会合并到请求体中）
# 例如 EasyClaw 需要 instance_id:
#   AGENT_EXTRA_BODY={"instance_id":"i-xxx","model":"main","llm_model":"deepv-easyclaw/kimi-k2.5"}
# AGENT_EXTRA_BODY={}

# ── 可选：LLM 裁判配置 ──
# 用另一个 LLM 做语义级别的 Pass/Fail 判定
# 不配置则 llm_judge / semantic_success 降级为关键词匹配
#
# 示例 (DeepSeek):
#   JUDGE_API_URL=https://api.deepseek.com/v1/chat/completions
#   JUDGE_API_KEY=sk-xxx
#   JUDGE_MODEL=deepseek-chat
#
# 示例 (OpenAI):
#   JUDGE_API_URL=https://api.openai.com/v1/chat/completions
#   JUDGE_API_KEY=sk-xxx
#   JUDGE_MODEL=gpt-4o-mini
JUDGE_API_URL=
JUDGE_API_KEY=
JUDGE_MODEL=

# ── 可选：运行参数 ──

# 请求间隔秒数，避免限频（默认 3）
# REQUEST_INTERVAL=3

# 最大重试次数（默认 2）
# MAX_RETRIES=2

# 报告输出目录（默认: 项目根/results）
# RESULTS_DIR=results
